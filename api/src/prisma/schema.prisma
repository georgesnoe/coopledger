generator client {
  provider = "prisma-client"
  output   = "../db"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id                    String        @id
  name                  String
  email                 String
  emailVerified         Boolean       @default(false)
  image                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  role                  UserRole      @default(USER)
  lastActiveAt          DateTime      @default(now())
  publicKey             String?
  encryptedPrivateKey   String?
  votes                 Votes[]
  voteCasts             VoteCasts[]
  sessions              Sessions[]
  accounts              Accounts[]
  transactions          Transactions[]
  memberships           Memberships[]
  cooperativesCreated   Cooperatives[]

  @@unique([email])
  @@map("users")
}

model Sessions {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  users     Users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("sessions")
}

model Accounts {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  users                 Users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("accounts")
}

model Verifications {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model Transactions {
  id              String              @id @default(uuid())
  amount          Float
  type            TransactionType
  status          TransactionStatus   @default(PENDING)
  blockchainHash  String?             @unique
  ipfsCid         String?
  receiptHash     String?
  userId          String
  user            Users               @relation(fields: [userId], references: [id], onDelete: Cascade)
  cooperativeId   String
  cooperative     Cooperatives        @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  voteId          String?
  vote            Votes?              @relation(fields: [voteId], references: [id])
  createdAt       DateTime            @default(now())
}

model Cooperatives {
  id                            String             @id @default(uuid())
  name                          String
  creatorId                     String
  description                   String
  logo                          String
  founders                      String[]

  latitude                      Float?
  longitude                     Float?

  publicKey                     String?
  encryptedPrivateKey           String?
  encryptionKey                 String?            // Clé AES de la coopérative (chiffrée avec ENCRYPTION_KEY du serveur)

  fedapayApiKeyPublic           String?
  fedapayApiKeySecret           String?
  payoutEnabled                 Boolean            @default(false)

  statusDocumentIpfsCid         String
  proofDocumentIpfsCid          String
  identityDocumentIpfsCid       String
  businessPlanDocumentIpfsCid   String?
  statusDocument                EncryptedDocument   @relation("StatusDocument", fields: [statusDocumentIpfsCid], references: [ipfsCid], onDelete: Cascade)
  proofDocument                 EncryptedDocument   @relation("ProofDocument", fields: [proofDocumentIpfsCid], references: [ipfsCid], onDelete: Cascade)
  identityDocument              EncryptedDocument   @relation("IdentityDocument", fields: [identityDocumentIpfsCid], references: [ipfsCid], onDelete: Cascade)
  businessPlanDocument          EncryptedDocument?  @relation("BusinessPlanDocument", fields: [businessPlanDocumentIpfsCid], references: [ipfsCid], onDelete: Cascade)
  creator                       Users               @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  members                       Memberships[]
  votes                         Votes[]
  transactions                  Transactions[]
  recurringFees                 RecurringFees[]
  createdAt                     DateTime            @default(now())
  updatedAt                     DateTime            @updatedAt
}

model Memberships {
  userId        String
  cooperativeId String
  status        MembershipStatus  @default(PENDING)
  grade         MembershipGrade   @default(MEMBER)
  role          MembershipRole    @default(FARMER)
  lastActiveAt  DateTime          @default(now())
  user          Users             @relation(fields: [userId], references: [id], onDelete: Cascade) 
  cooperative   Cooperatives      @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@id([userId, cooperativeId])
}

model RecurringFees {
  id              String          @id @default(uuid())
  cooperativeId   String
  cooperative     Cooperatives    @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  amount          Float
  frequency       FeeFrequency    @default(MONTHLY)
  description     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model EncryptedDocument {
  ipfsCid                 String         @id
  iv                      String
  tag                     String

  statusDocumentOf        Cooperatives[] @relation("StatusDocument")
  proofDocumentOf         Cooperatives[] @relation("ProofDocument")
  identityDocumentOf      Cooperatives[] @relation("IdentityDocument")
  businessPlanDocumentOf  Cooperatives[] @relation("BusinessPlanDocument")
  createdAt               DateTime       @default(now())
}

model Votes {
  id                      String         @id @default(uuid())
  cooperativeId           String
  cooperative             Cooperatives   @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  type                    VoteType       @default(VOTE_GENERAL)
  status                  VoteStatus     @default(OPEN)
  subject                 String
  description             String?
  proposals               String[]
  amount                  Float?         // Pour COTISATION ou RETRAIT
  beneficiary             String?        // Pour RETRAIT (numéro mobile)
  endDate                 DateTime
  paymentDeadline         DateTime?      // Pour COTISATION
  totalEligibleVoters     Int            @default(0)
  creatorId               String
  creator                 Users          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  VoteCasts               VoteCasts[]
  transactions            Transactions[]
}

model VoteCasts {
  id                      String         @id @default(uuid())
  voteId                  String
  userId                  String
  user                    Users          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vote                    Votes          @relation(fields: [voteId], references: [id], onDelete: Cascade)
  createdAt               DateTime       @default(now())
}

enum MembershipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum TransactionType {
  COTISATION
  RETRAIT
}

enum VoteStatus {
  OPEN
  APPROVED
  REJECTED
  EXPIRED
}

enum VoteType {
  VOTE_GENERAL
  COTISATION
  RETRAIT
  CANDIDATURE_BUREAU
}

enum FeeFrequency {
  MONTHLY
  YEARLY
}

enum UserRole {
  USER
  ADMIN
}

enum MembershipGrade {
  ADMIN
  TREASURER
  MEMBER
}

enum MembershipRole {
  FARMER
  SELLER
}

