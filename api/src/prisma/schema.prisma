generator client {
  provider = "prisma-client"
  output   = "../db"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id                    String        @id
  name                  String
  email                 String
  emailVerified         Boolean       @default(false)
  image                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  role                  UserRole      @default(USER)
  publicKey             String?
  encryptedPrivateKey   String?
  votes                 Votes[]
  voteCasts             VoteCasts[]
  sessions              Sessions[]
  accounts              Accounts[]
  transactions          Transactions[]
  memberships           Memberships[]
  cooperativesCreated   Cooperatives[]

  @@unique([email, publicKey])
  @@map("users")
}

model Sessions {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  users     Users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("sessions")
}

model Accounts {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  users                 Users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("accounts")
}

model Verifications {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model Transactions {
  id              String              @id @default(uuid())
  amount          Float
  type            String
  status          TransactionStatus   @default(PENDING)
  blockchainHash  String?             @unique
  ipfsCid         String?
  userId          String
  user            Users               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime            @default(now())
}

model Cooperatives {
  id                            String             @id @default(uuid())
  name                          String
  creatorId                     String
  description                   String
  logo                          String
  founders                      String[]
  statusDocumentIpfsCid         String
  proofDocumentIpfsCid          String
  identityDocumentIpfsCid       String
  businessPlanDocumentIpfsCid   String?
  statusDocument                EncryptedDocument   @relation("StatusDocument", fields: [statusDocumentIpfsCid], references: [ipfsCid], onDelete: Cascade)
  proofDocument                 EncryptedDocument   @relation("ProofDocument", fields: [proofDocumentIpfsCid], references: [ipfsCid], onDelete: Cascade)
  identityDocument              EncryptedDocument   @relation("IdentityDocument", fields: [identityDocumentIpfsCid], references: [ipfsCid], onDelete: Cascade)
  businessPlanDocument          EncryptedDocument?  @relation("BusinessPlanDocument", fields: [businessPlanDocumentIpfsCid], references: [ipfsCid], onDelete: Cascade)
  creator                       Users               @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  members                       Memberships[]
  createdAt                     DateTime            @default(now())
  updatedAt                     DateTime            @updatedAt
}

model Memberships {
  userId        String
  cooperativeId String
  status        MembershipStatus  @default(PENDING)
  grade         MembershipGrade   @default(MEMBER)
  role          MembershipRole    @default(FARMER)
  user          Users             @relation(fields: [userId], references: [id], onDelete: Cascade) 
  cooperative   Cooperatives      @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@id([userId, cooperativeId])
}

model EncryptedDocument {
  ipfsCid                 String         @id
  iv                      String
  tag                     String

  statusDocumentOf        Cooperatives[] @relation("StatusDocument")
  proofDocumentOf         Cooperatives[] @relation("ProofDocument")
  identityDocumentOf      Cooperatives[] @relation("IdentityDocument")
  businessPlanDocumentOf  Cooperatives[] @relation("BusinessPlanDocument")
  createdAt               DateTime       @default(now())
}

model Votes {
  id                      String         @id @default(uuid())
  subject                 String
  proposals               String[]
  endDate                 DateTime
  creatorId               String
  creator                 Users          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt               DateTime       @default(now())

  VoteCasts               VoteCasts[]
}

model VoteCasts {
  id                      String         @id @default(uuid())
  voteId                  String
  userId                  String
  user                    Users          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vote                    Votes          @relation(fields: [voteId], references: [id], onDelete: Cascade)
  createdAt               DateTime       @default(now())
}

enum MembershipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum UserRole {
  USER
  ADMIN
}

enum MembershipGrade {
  ADMIN
  TREASURER
  MEMBER
}

enum MembershipRole {
  FARMER
  SELLER
}

